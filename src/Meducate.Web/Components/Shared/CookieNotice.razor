@inject IJSRuntime JS

@if (_visible)
{
    <div class="position-fixed bottom-0 start-0 end-0 text-white px-3 py-2 d-flex align-items-center justify-content-center gap-3 small border-top" style="z-index: 1050; background-color: #1a1a2e;">
        <span>This site uses functional cookies only (authentication and theme preference). No tracking or advertising.</span>
        <button class="btn btn-sm btn-outline-light" @onclick="Dismiss">OK</button>
    </div>
}

@code {
    private bool _visible;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var dismissed = await JS.InvokeAsync<string?>("localStorage.getItem", "cookieNoticeDismissed");
            if (dismissed is null)
            {
                _visible = true;
                StateHasChanged();
            }
        }
    }

    private async Task Dismiss()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "cookieNoticeDismissed", "1");
        _visible = false;
    }
}
